{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Outset",
  "version": "0.0.1",
  "identifier": "com.outset.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Outset",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 22 },
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Spec-driven development with Claude",
    "longDescription": "Outset is a macOS app for spec-driven development with Claude Code. Manage projects as folders, write structured specs in markdown, and run multiple AI sessions per project.",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mattproch/outset/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREMUY2RDA0NDI1OTM1NDgKUldSSU5WbENCRzBmVFlzRjVPclVhQkRLMFBxaGY1UzZmbVZoQmY0NXVjWk9lVGZYSXBaUitsSmIK"
    }
  }
}
